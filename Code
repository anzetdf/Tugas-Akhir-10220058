<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <title>Simulasi Futsal 1v1 - Data Sampling</title>
    <style>
        :root {
            --bg-dark: #121212;
            --bg-panel: #1e1e1e;
            --text-light: #e0e0e0;
            --text-muted: #a0a0a0;
            --accent-blue: #007bff;
            --accent-green: #00c853;
            --accent-yellow: #ffd600;
            --accent-red: #d50000;
        }
        body {
            background-color: var(--bg-dark);
            color: var(--text-light); 
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            margin: 0;
            padding: 20px;
            display: flex;
            justify-content: center;
            align-items: flex-start;
            min-height: 100vh;
            gap: 20px;
        }
        
        /* Layout Grid */
        .container {
            display: flex;
            gap: 25px;
            background-color: var(--bg-panel);
            padding: 30px;
            border-radius: 12px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.5);
            align-items: flex-start;
        }

        .sidebar { width: 280px; display: flex; flex-direction: column; gap: 20px; }
        .canvas-area { border-radius: 12px; overflow: hidden; border: 2px solid #333; }
        
        /* Buttons & Panels */
        button {
            padding: 12px; font-size: 16px; font-weight: bold;
            border: none; border-radius: 8px; cursor: pointer;
            transition: background 0.2s; color: white; margin-bottom: 5px;
        }
        #shootBtn { background-color: var(--accent-blue); }
        #shootBtn:hover { background-color: #0056b3; }
        #scanBtn { background-color: #6200ea; } /* Warna Ungu untuk Data */
        #scanBtn:hover { background-color: #3700b3; }

        .panel { background: #2a2a2a; padding: 15px; border-radius: 8px; }
        .panel-label { font-size: 12px; color: var(--text-muted); display: block; margin-bottom: 5px; }
        .panel-value { font-size: 18px; font-weight: bold; }
        
        /* xG Visuals */
        .xg-main-value { font-size: 32px; font-weight: 800; color: var(--accent-green); display: block; text-align: center; }
        .xg-bar-container { height: 10px; background: #444; border-radius: 5px; overflow: hidden; margin-top: 10px; }
        #xgBar { height: 100%; width: 0%; background: var(--accent-green); transition: width 0.3s; }

        /* DATA TABLE (New Feature) */
        .data-results {
            margin-top: 10px;
            max-height: 200px;
            overflow-y: auto;
            background: #111;
            padding: 10px;
            border-radius: 8px;
            font-family: monospace;
            font-size: 12px;
            border: 1px solid #444;
        }
        table { width: 100%; border-collapse: collapse; }
        th, td { text-align: left; padding: 4px; border-bottom: 1px solid #333; }
        th { color: var(--accent-yellow); }
    </style>
</head>
<body>

<div class="container">
    <div class="sidebar">
        <h2 style="margin:0">Futsal Kinematics</h2>
        <div style="font-size:12px; color:#888;">Draft TA 10220058</div>

        <div style="display:flex; flex-direction:column; gap:10px;">
            <button id="shootBtn" onclick="shoot()">TEMBAK (SHOOT)</button>
            <button id="scanBtn" onclick="scanFieldData()">AMBIL DATA (CSV EXPORT)</button>
        </div>

        <div class="panel">
            <span class="panel-label">Konfigurasi Agen</span>
            <label class="panel-label">Tipe Striker (ST)</label>
            <select id="stSelect" onchange="updateConfig()" style="width:100%; margin-bottom:10px; padding:5px; background:#333; color:white; border:1px solid #555; border-radius:4px;">
                <option value="1">ST 1: Tiang Dekat</option>
                <option value="2" selected>ST 2: Tiang Jauh</option>
                <option value="3">ST 3: Celah Terlebar</option>
            </select>
            <button id="stToggleBtn" onclick="toggleStMove()" style="width:100%; padding:8px; margin-bottom:10px; font-size:12px; background:var(--accent-green); border:none; color:white;">Gerak ST: AUTO</button>
            
            <label class="panel-label">Tipe Kiper (GK)</label>
            <select id="gkSelect" onchange="updateConfig()" style="width:100%; padding:5px; background:#333; color:white; border:1px solid #555; border-radius:4px;">
                <option value="1" selected>GK 1: Gerak Sinusoidal</option>
                <option value="2">GK 2: Bisektor (Optimal)</option>
                <option value="3">GK 3: Refleks (Radius+)</option>
            </select>
        </div>

        <div class="panel">
            <span class="panel-label">Parameter Fisika</span>
            <label class="panel-label">Kecepatan Bola: <span id="ballSpeedVal">26</span> m/s</label>
            <input type="range" id="ballSpeedInput" min="10" max="45" value="26" style="width:100%" oninput="updatePhysics()">
            
            <label class="panel-label" style="margin-top:10px">Waktu Refleks GK: <span id="reflexTimeVal">200</span> ms</label>
            <input type="range" id="reflexTimeInput" min="50" max="500" step="10" value="200" style="width:100%" oninput="updatePhysics()">
        </div>

        <div class="panel">
            <span class="panel-label">Visualisasi</span>
            <label style="display:flex; align-items:center; gap:10px; cursor:pointer; font-size:14px;">
                <input type="checkbox" id="heatmapToggle" onchange="toggleHeatmap()"> Tampilkan Heatmap xG
            </label>
        </div>

        <div class="panel">
            <span class="panel-label">Analisis Realtime</span>
            <div style="display:flex; justify-content:space-between; align-items:flex-end;">
                <div>
                    <span class="panel-label">xG (Peluang)</span>
                    <span id="xgLiveVal" style="font-size:28px; font-weight:800; color:var(--accent-red);">0.00</span>
                </div>
                <div style="text-align:right;">
                    <span class="panel-label">Jarak</span>
                    <span id="distLiveVal" style="font-size:20px; font-weight:bold;">0.00 m</span>
                </div>
            </div>
            <div class="xg-bar-container" style="margin-top:5px; background:#333;">
                <div id="xgLiveBar" style="height:100%; width:0%; background:var(--accent-red); transition: width 0.1s;"></div>
            </div>
        </div>

        <div class="panel">
            <span class="panel-label">Cakupan Gawang (Realtime)</span>
            <div style="display:flex; justify-content:space-between; margin-bottom:5px; font-size:14px;">
                <span style="color:var(--accent-red)">Covered: <span id="covVal">0.00</span>m</span>
                <span style="color:var(--accent-green)">Open: <span id="openVal">3.00</span>m</span>
            </div>
            <div style="text-align:center; margin-bottom:5px; font-size:14px;">
                <span style="color:var(--accent-yellow)">Open Angle: <span id="openAngleVal">0.00</span>°</span>
            </div>
            <div class="xg-bar-container">
                <div id="covBar" style="height:100%; width:0%; background:var(--accent-red); float:left; transition: width 0.1s;"></div>
                <div id="openBar" style="height:100%; width:100%; background:var(--accent-green); float:left; transition: width 0.1s;"></div>
            </div>
        </div>

        <div class="panel">
            <span class="panel-label">Hasil Sampling Data (xG vs Posisi)</span>
            <div class="data-results" id="dataOutput">
                <em>Klik "Ambil Data" untuk generate tabel...</em>
            </div>
        </div>
    </div>

    <div class="canvas-area">
        <canvas id="fieldCanvas" width="800" height="900"></canvas>
    </div>
</div>

<script>
    const canvas = document.getElementById('fieldCanvas');
    const ctx = canvas.getContext('2d');
    const SCALE = 35; 
    const ORIGIN_X = canvas.width / 2; 
    const ORIGIN_Y = canvas.height - 50;

    // --- AGEN ---
    let gk = { x0: 0, A: 1.8, omega: (2*Math.PI)/3, phi: 0, y_pos: 1, limit_left: -1.5, limit_right: 1.5, radius_block: 0.40, x_curr: 0, diveTimer: 0 };
    let st = { x0: 0, A: 7.0, omega: 0.2, phi: Math.PI/2, y_pos: 6, x_curr: 0, manual: false };
    let ball = { active: false, x: 0, y: 0, vx: 0, vy: 0 };
    let t = 0; let dt = 0.016; 
    
    // Variabel Global xG
    let currentXG = 0;
    let coverageStats = { covered: 0, open: 3.0, x1: 0, x2: 0 };
    
    // Konfigurasi
    let stType = 2;
    let gkType = 1; 
    let ballSpeed = 26;
    let gkReflexTime = 200;
    let showHeatmap = false;
    let matchResult = { text: "", color: "", timer: 0, opacity: 0 }; // Variabel Animasi
    let shotTime = 0; // Waktu saat bola ditendang
    let lastUIUpdate = 0; // Variabel untuk throttling UI

    function tx(meters) { return ORIGIN_X + (meters * SCALE); }
    function ty(meters) { return ORIGIN_Y - (meters * SCALE); }

    // --- FUNGSI UTAMA: CALCULATE xG ---
    // Menggunakan rumus: xG = (Theta_Open / Theta_Goal) * (1 - 1 / (1 + e^(-lambda * (t_gk - t_ball))))
    function calculateXG(test_x = null, test_y = null) {
        const x = (test_x !== null) ? test_x : st.x_curr;
        const y = (test_y !== null) ? test_y : st.y_pos;
        
        // 1. Hitung Geometri & Posisi Optimal Kiper (Bisektor)
        let angleLeft = Math.atan2(0 - y, -1.5 - x);
        let angleRight = Math.atan2(0 - y, 1.5 - x);
        let bisector = (angleLeft + angleRight) / 2;
        
        let dy = gk.y_pos - y;
        let gkX = x + (dy / Math.tan(bisector));
        
        // 2. Hitung Rasio Sudut (Theta Open / Theta Goal)
        // Coverage: Proyeksi blokade kiper
        let distStToGk = Math.max(0.1, y - gk.y_pos);
        let scale = y / distStToGk;
        let projX = x + (gkX - x) * scale;
        let projR = gk.radius_block * scale;
        
        let x1 = Math.max(projX - projR, -1.5);
        let x2 = Math.min(projX + projR, 1.5);
        let covered = Math.max(0, x2 - x1);
        let open = 3.0 - covered; // Lebar gawang terbuka (meter)
        
        // Ratio Sudut ~ Ratio Lebar (Approksimasi Linear)
        let angleRatio = open / 3.0;

        // 3. Hitung Probabilitas Waktu (Logistic Function)
        let dist = Math.sqrt(x*x + y*y);
        let t_ball = dist / ballSpeed;        // Waktu tempuh bola (detik)
        
        // Tambahkan 0.3s (300ms) untuk estimasi waktu gerak tubuh/diving kiper
        let t_gk = (gkReflexTime / 1000.0) + 0.30; 
        
        // Lambda: Sensitivitas waktu. Nilai negatif (-8.0) digunakan agar:
        // Jika t_ball (kecil) < t_gk (besar) [Gol Mudah] -> Diff Positif -> Logistic Term Kecil -> (1 - Term) Besar.
        let lambda = -8.0; 
        
        let logisticTerm = 1.0 / (1.0 + Math.exp(-lambda * (t_gk - t_ball)));
        let timeProbability = 1.0 - logisticTerm;
        
        let xgVal = angleRatio * timeProbability;

        // Batas Bawah & Atas
        if (xgVal < 0.0) xgVal = 0.0;
        if (xgVal > 0.99) xgVal = 0.99;
        
        // Override: Jika sudah melewati garis pertahanan kiper
        if (y <= gk.y_pos + 0.2) xgVal = 0.99;
        
        return xgVal;
    }

    function updateConfig() {
        stType = parseInt(document.getElementById('stSelect').value);
        gkType = parseInt(document.getElementById('gkSelect').value);
    }

    function toggleStMove() {
        st.manual = !st.manual;
        updateStBtnUI();
    }

    function updateStBtnUI() {
        const btn = document.getElementById('stToggleBtn');
        if(st.manual) {
            btn.innerText = "Gerak ST: MANUAL (Diam)";
            btn.style.background = "#555";
        } else {
            btn.innerText = "Gerak ST: AUTO";
            btn.style.background = "var(--accent-green)";
        }
    }

    function updatePhysics() {
        ballSpeed = parseInt(document.getElementById('ballSpeedInput').value);
        gkReflexTime = parseInt(document.getElementById('reflexTimeInput').value);
        document.getElementById('ballSpeedVal').innerText = ballSpeed;
        document.getElementById('reflexTimeVal').innerText = gkReflexTime;
    }

    function toggleHeatmap() {
        showHeatmap = document.getElementById('heatmapToggle').checked;
    }

    function updateCoverage() {
        // Hitung Proyeksi Blokade Kiper ke Garis Gawang (y=0)
        let distStToGoal = st.y_pos; // Jarak Striker ke Garis Gawang
        let distStToGk = st.y_pos - gk.y_pos; // Jarak Striker ke Kiper
        
        // Hindari pembagian nol atau nilai negatif aneh
        if (distStToGk < 0.1) distStToGk = 0.1;

        let scale = distStToGoal / distStToGk;
        
        // Pusat bayangan di garis gawang
        let projX = st.x_curr + (gk.x_curr - st.x_curr) * scale;
        
        // Radius bayangan (Linear Projection)
        let projR = gk.radius_block * scale;
        
        // Interval Blokade
        let blockLeft = projX - projR;
        let blockRight = projX + projR;
        
        // Interval Gawang (-1.5 sampai 1.5)
        let goalLeft = -1.5;
        let goalRight = 1.5;
        
        // Interseksi (Bagian gawang yang tertutup)
        let x1 = Math.max(blockLeft, goalLeft);
        let x2 = Math.min(blockRight, goalRight);
        
        let covered = Math.max(0, x2 - x1);
        let open = 3.0 - covered;

        // --- Hitung Open Angle Realtime ---
        let angL = Math.atan2(0 - st.y_pos, -1.5 - st.x_curr);
        let angR = Math.atan2(0 - st.y_pos, 1.5 - st.x_curr);
        let goalAngle = Math.abs(angL - angR);
        let openAngleRad = goalAngle * (open / 3.0);
        let openAngleDeg = openAngleRad * (180 / Math.PI);
        
        // Hitung Jarak & xG Realtime
        let dist = Math.sqrt(st.x_curr*st.x_curr + st.y_pos*st.y_pos);
        let xg = calculateXG();

        // Simpan ke global untuk drawing
        coverageStats = { covered, open, x1, x2 };
        
        // Update UI (Throttling: Hanya update setiap 100ms agar slider tidak berat)
        const now = performance.now();
        if (now - lastUIUpdate > 100) {
            lastUIUpdate = now;
            document.getElementById('covVal').innerText = covered.toFixed(2);
            document.getElementById('openVal').innerText = open.toFixed(2);
            document.getElementById('openAngleVal').innerText = openAngleDeg.toFixed(1);
            
            // Update Panel Analisis Realtime
            document.getElementById('distLiveVal').innerText = dist.toFixed(2) + " m";
            document.getElementById('xgLiveVal').innerText = xg.toFixed(2);
            let xgColor = xg > 0.7 ? "var(--accent-green)" : xg > 0.3 ? "var(--accent-yellow)" : "var(--accent-red)";
            document.getElementById('xgLiveVal').style.color = xgColor;
            document.getElementById('xgLiveBar').style.width = (xg * 100) + "%";
            document.getElementById('xgLiveBar').style.background = xgColor;
            
            let covPct = (covered / 3.0) * 100;
            document.getElementById('covBar').style.width = covPct + "%";
            document.getElementById('openBar').style.width = (100 - covPct) + "%";
        }
    }

    // --- FUNGSI BARU: EKSPOR DATA CSV (BATCH) ---
    function scanFieldData() {
        // Konfigurasi Sampling
        const speeds = [15, 25, 35];
        const iterations = 100;
        const yStart = 1.5, yEnd = 20, yStep = 0.5;
        const xStart = -10, xEnd = 10, xStep = 0.5;
        
        // Simpan state asli
        const originalStX = st.x_curr;
        const originalStY = st.y_pos;
        const originalSpeed = ballSpeed;
        const originalGkType = gkType;
        const originalStType = stType;
        
        // Paksa Tipe Agen (ST 3 & GK 3)
        gkType = 3; 
        stType = 3; 
        gk.radius_block = 0.40; // Reset radius standar
        
        let csvContent = "data:text/csv;charset=utf-8,";
        csvContent += "Batch_Speed,Reflex_ms,GK_Type,Max_Reach,X,Y,Dist,Open_Angle_Rad,Open_Angle_Deg,xG,Goals_per_100,Outcome\n";
        
        document.getElementById('dataOutput').innerHTML = "<em>Sedang memproses data batch... Mohon tunggu.</em>";
        console.log("--- MULAI EKSPOR DATA SIMULASI (BATCH) ---");
        
        // Loop Batch Speed
        speeds.forEach(speed => {
            ballSpeed = speed;
            console.log(`Processing Batch Speed: ${speed} m/s...`);
            
            for (let y = yStart; y <= yEnd; y += yStep) {
                for (let x = xStart; x <= xEnd; x += xStep) {
                    // Setup Posisi
                    st.x_curr = x;
                    st.y_pos = y;
                    
                    // 1. Hitung xG (Teoretis)
                    let xgVal = calculateXG();
                    
                    // Hitung Open Angle (Replikasi Logika Geometri)
                    let angleLeft = Math.atan2(0 - y, -1.5 - x);
                    let angleRight = Math.atan2(0 - y, 1.5 - x);
                    // GK Position (Optimal/Bisektor)
                    let bisector = (angleLeft + angleRight) / 2;
                    let dy = gk.y_pos - y;
                    let gkX = x + (dy / Math.tan(bisector));
                    
                    // Coverage
                    let distStToGk = Math.max(0.1, y - gk.y_pos);
                    let scale = y / distStToGk;
                    let projX = x + (gkX - x) * scale;
                    let projR = gk.radius_block * scale;
                    
                    let x1 = Math.max(projX - projR, -1.5);
                    let x2 = Math.min(projX + projR, 1.5);
                    let covered = Math.max(0, x2 - x1);
                    let open = 3.0 - covered;
                    let goalAngle = Math.abs(angleLeft - angleRight);
                    let openAngleRad = goalAngle * (open / 3.0);
                    let openAngleDeg = openAngleRad * (180 / Math.PI);

                    // 2. Simulasi Fisika (Probabilistik dengan Noise)
                    let goalCount = 0;
                    for(let i=0; i<iterations; i++) {
                        // useNoise = true untuk variasi akurasi
                        if(simulatePhysicsOutcome(x, y, speed, gkReflexTime, true)) goalCount++;
                    }
                    let goals = goalCount;
                    
                    // Klasifikasi Outcome (3 Kategori)
                    let outcome = "";
                    if (goals < 30) outcome = "SULIT";      // < 30%
                    else if (goals < 70) outcome = "BISA";  // 30% - 70%
                    else outcome = "MUDAH";                 // > 70%
                    
                    let dist = Math.sqrt(x*x + y*y);
                    let maxReach = (gkType === 3) ? 0.6 : 0.4;
                    
                    // Tambah ke CSV
                    csvContent += `${speed},${gkReflexTime},${gkType},${maxReach},${x},${y},${dist.toFixed(2)},${openAngleRad.toFixed(4)},${openAngleDeg.toFixed(2)},${xgVal.toFixed(4)},${goals},${outcome}\n`;
                }
            }
        });
        
        // Restore State
        st.x_curr = originalStX;
        st.y_pos = originalStY;
        ballSpeed = originalSpeed;
        gkType = originalGkType;
        stType = originalStType;
        updatePhysics(); 
        
        // Download File
        const encodedUri = encodeURI(csvContent);
        const link = document.createElement("a");
        link.setAttribute("href", encodedUri);
        link.setAttribute("download", "futsal_simulation_data.csv");
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
        
        document.getElementById('dataOutput').innerHTML = "<em>Data berhasil diekspor ke CSV!</em>";
        alert("Export Selesai! File .csv sedang diunduh.");
    }

    // Helper: Simulasi Fisika tanpa Rendering
    function simulatePhysicsOutcome(stX, stY, speed, reflexTime, useNoise = false) {
        // 1. Setup GK di Posisi Optimal Awal (Bisektor)
        let angleLeft = Math.atan2(0 - stY, -1.5 - stX);
        let angleRight = Math.atan2(0 - stY, 1.5 - stX);
        let bisector = (angleLeft + angleRight) / 2;
        let dy = gk.y_pos - stY;
        let gkX = stX + (dy / Math.tan(bisector));
        
        // State Awal Simulasi
        let simGkX = gkX;
        let simBallX = stX;
        let simBallY = stY;
        
        // Radius Lokal untuk Simulasi (Agar tidak merusak global state)
        let simRadius = 0.40;
        
        // Tentukan Target Tembakan (ST 3 Logic)
        let distLeft = Math.abs(simGkX - (-1.3));
        let distRight = Math.abs(simGkX - 1.3);
        let targetX = (distLeft > distRight) ? -1.3 : 1.3;
        
        // --- NOISE AKURASI (Agar data tidak biner 0/100) ---
        if (useNoise) {
            // Error acak +/- 0.3 meter pada target tembakan
            targetX += (Math.random() - 0.5) * 0.6;
        }
        
        // Kecepatan Bola
        let dx = targetX - simBallX;
        let dyBall = 0 - simBallY;
        let d = Math.sqrt(dx*dx + dyBall*dyBall);
        let vx = (dx/d) * speed;
        let vy = (dyBall/d) * speed;
        
        // Loop Waktu
        let simT = 0;
        let dtSim = 0.016;
        let maxTime = 5.0; 
        
        while (simT < maxTime) {
            simT += dtSim;
            simBallX += vx * dtSim;
            simBallY += vy * dtSim;
            
            // Update Posisi GK
            let timeSinceShotMs = simT * 1000;
            if (timeSinceShotMs > reflexTime) {
                let interceptX = simBallX + (gk.y_pos - simBallY) * (vx / vy);
                simGkX += (interceptX - simGkX) * 0.08;
            } else {
                // Tracking (Idle)
                let aL = Math.atan2(0 - stY, -1.5 - stX);
                let aR = Math.atan2(0 - stY, 1.5 - stX);
                let bS = (aL + aR) / 2;
                let dY = gk.y_pos - stY;
                let tX = stX + (dY / Math.tan(bS));
                simGkX += (tX - simGkX) * 0.1;
            }
            
            // GK 3: Refleks Membesar (Simulasi)
            if (gkType === 3 && simRadius < 0.6) {
                let expansionRate = (0.2 / (reflexTime / 1000)) * dtSim;
                simRadius += expansionRate;
            }
            
            // Cek Tabrakan (Block)
            if (simBallY <= gk.y_pos && simBallY >= gk.y_pos - 0.5) {
                if (Math.abs(simBallX - simGkX) <= gk.radius_block) return false; // Blocked
                if (Math.abs(simBallX - simGkX) <= simRadius) return false; // Blocked
            }
            
            // Cek Gawang (Goal/Miss)
            if (simBallY <= 0) {
                let exactX = simBallX - (simBallY / vy) * vx;
                if (Math.abs(exactX) <= 1.5) return true; // Goal
                return false; // Miss
            }
        }
        return false;
    }

    // --- VISUALISASI ---
    function drawField() {
        ctx.clearRect(0,0,canvas.width,canvas.height);
        
        // Lapangan (Background)
        ctx.fillStyle = "#1a2e1a"; 
        ctx.fillRect(tx(-10), ty(0), 20*SCALE, -20*SCALE);

        // --- HEATMAP xG ---
        if (showHeatmap) {
            for (let x = -10; x < 10; x++) {
                for (let y = 0; y < 20; y++) {
                    // Hitung xG di tengah grid (x+0.5, y+0.5)
                    let val = calculateXG(x + 0.5, y + 0.5);
                    
                    // Tentukan Warna (Transparan)
                    if (val > 0.7) ctx.fillStyle = "rgba(0, 200, 83, 0.35)"; // Hijau
                    else if (val > 0.4) ctx.fillStyle = "rgba(255, 214, 0, 0.35)"; // Kuning
                    else ctx.fillStyle = "rgba(213, 0, 0, 0.35)"; // Merah
                    
                    // Gambar Kotak Grid
                    ctx.fillRect(tx(x), ty(y+1), SCALE, SCALE);
                }
            }
        }

        // Grid 1x1 Meter
        ctx.strokeStyle = "rgba(255, 255, 255, 0.1)";
        ctx.lineWidth = 1;
        ctx.beginPath();
        for (let x = -10; x <= 10; x++) {
            ctx.moveTo(tx(x), ty(0)); ctx.lineTo(tx(x), ty(20));
        }
        for (let y = 0; y <= 20; y++) {
            ctx.moveTo(tx(-10), ty(y)); ctx.lineTo(tx(10), ty(y));
        }
        ctx.stroke();

        // Garis Luar
        ctx.strokeStyle="white"; ctx.lineWidth=2; ctx.beginPath();
        ctx.rect(tx(-10), ty(0), 20*SCALE, -20*SCALE); ctx.stroke();
        ctx.beginPath(); ctx.arc(tx(0), ty(20), 3*SCALE, 0, Math.PI); ctx.stroke(); // Lingkaran Tengah
        ctx.beginPath(); ctx.arc(tx(0), ty(0), 6*SCALE, Math.PI, 0); ctx.stroke(); // Area Penalti
        
        // Garis Lintasan Agen
        ctx.strokeStyle="rgba(255, 255, 255, 0.08)"; // Lintasan Kiper (Sangat Halus)
        ctx.beginPath(); ctx.moveTo(tx(gk.x0 - gk.A),ty(gk.y_pos)); ctx.lineTo(tx(gk.x0 + gk.A),ty(gk.y_pos)); ctx.stroke();
        
        ctx.strokeStyle="rgba(0, 255, 255, 0.15)"; // Lintasan Striker (Agak Halus)
        ctx.beginPath(); ctx.moveTo(tx(-9.5),ty(st.y_pos)); ctx.lineTo(tx(9.5),ty(st.y_pos)); ctx.stroke();

        // Label
        // Label batas dihapus karena kiper bergerak bebas
        
        // Gawang
        ctx.lineWidth = 5; // Gawang lebih tebal
        ctx.strokeStyle="#fff"; ctx.strokeRect(tx(-1.5), ty(0), 3*SCALE, 10);
        ctx.lineWidth = 2; // Reset

        // Visualisasi Coverage (Garis Merah di Gawang)
        if (coverageStats.covered > 0.01) {
            ctx.strokeStyle = "#ff0000";
            ctx.lineWidth = 5;
            ctx.beginPath();
            ctx.moveTo(tx(coverageStats.x1), ty(0));
            ctx.lineTo(tx(coverageStats.x2), ty(0));
            ctx.stroke();
            
            // Garis Proyeksi (Cone)
            ctx.strokeStyle = "rgba(255, 0, 0, 0.15)";
            ctx.lineWidth = 1;
            ctx.beginPath();
            ctx.moveTo(tx(st.x_curr), ty(st.y_pos)); ctx.lineTo(tx(coverageStats.x1), ty(0));
            ctx.moveTo(tx(st.x_curr), ty(st.y_pos)); ctx.lineTo(tx(coverageStats.x2), ty(0));
            ctx.stroke();
        }
    }

    function drawLabel(text, x, y, align, color="red") {
        ctx.fillStyle=color; ctx.beginPath(); ctx.arc(tx(x), ty(y), 4, 0, Math.PI*2); ctx.fill();
        ctx.fillStyle="#fff"; ctx.font="10px Arial"; ctx.textAlign=align;
        ctx.fillText(text, tx(x)+(align=="left"?8:-8), ty(y)-8);
    }

    function drawAgents() {
        // Kiper
        ctx.fillStyle = gk.diveTimer > 0 ? "#ff00ff" : "yellow"; ctx.beginPath(); ctx.arc(tx(gk.x_curr),ty(gk.y_pos), gk.radius_block * SCALE, 0,Math.PI*2); ctx.fill();
        // 1. Area Jangkauan (Hitbox) - Transparan
        ctx.fillStyle = gk.diveTimer > 0 ? "rgba(255, 0, 255, 0.3)" : "rgba(255, 255, 0, 0.2)"; 
        ctx.beginPath(); ctx.arc(tx(gk.x_curr),ty(gk.y_pos), gk.radius_block * SCALE, 0,Math.PI*2); ctx.fill();
        
        // 2. Body Kiper (Inti) - Solid
        ctx.fillStyle = gk.diveTimer > 0 ? "#ff00ff" : "yellow"; ctx.beginPath(); ctx.arc(tx(gk.x_curr),ty(gk.y_pos), 8, 0,Math.PI*2); ctx.fill();
        
        // Striker
        ctx.fillStyle="#ff4444"; ctx.beginPath(); ctx.arc(tx(st.x_curr),ty(st.y_pos),7,0,Math.PI*2); ctx.fill();
        
        // Bola
        if(ball.active){ ctx.fillStyle="white"; ctx.beginPath(); ctx.arc(tx(ball.x),ty(ball.y),5,0,Math.PI*2); ctx.fill(); }
    }

    function update() {
        if(gk.diveTimer > 0) gk.diveTimer--;

        t+=dt; // Waktu global terus berjalan (untuk animasi & logika refleks)

        if(!ball.active) { 
            updateCoverage();
        }
        
        // Reset radius jika GK 3 tidak aktif atau bola reset
        if(!ball.active && gk.radius_block > 0.40) gk.radius_block = 0.40;
        
        if (!ball.active) {
            if (gkType === 1) {
                // GK 1: Sinusoidal (Bolak-balik)
                gk.x_curr = gk.x0 + gk.A * Math.sin(gk.omega * t + gk.phi);
            } else {
                // GK 2 & 3: Posisi Optimal (Bisektor Sudut)
                // Hitung sudut ke tiang kiri (-1.5) dan kanan (1.5)
                let angleLeft = Math.atan2(0 - st.y_pos, -1.5 - st.x_curr);
                let angleRight = Math.atan2(0 - st.y_pos, 1.5 - st.x_curr);
                let bisector = (angleLeft + angleRight) / 2;
                
                // Hitung posisi x pada y = gk.y_pos
                let dy = gk.y_pos - st.y_pos;
                let targetX = st.x_curr + (dy / Math.tan(bisector));
                
                // Smoothing gerak
                gk.x_curr += (targetX - gk.x_curr) * 0.1;
            }
        } else {
            if (gkType === 1) {
                // GK 1 Tetap bergerak pola saat bola ditendang
                gk.x_curr = gk.x0 + gk.A * Math.sin(gk.omega * t + gk.phi);
            } 
            // GK 2 & 3: Reaksi ke bola dengan DELAY REFLEKS
            else {
                // Cek apakah waktu reaksi sudah lewat
                let timeSinceShot = (t - shotTime) * 1000; // dalam ms
                
                if (timeSinceShot > gkReflexTime) {
                    // GK 2 & 3: Reaksi ke bola (Mencoba blok)
                    let interceptX = ball.x + (gk.y_pos - ball.y) * (ball.vx / ball.vy);
                    gk.x_curr += (interceptX - gk.x_curr) * 0.08;
                } else {
                    // SELAMA REFLEKS (Belum sadar): Tetap tracking striker (Idle)
                    // Agar tidak freeze saat bola melaju
                    let angleLeft = Math.atan2(0 - st.y_pos, -1.5 - st.x_curr);
                    let angleRight = Math.atan2(0 - st.y_pos, 1.5 - st.x_curr);
                    let bisector = (angleLeft + angleRight) / 2;
                    let dy = gk.y_pos - st.y_pos;
                    let targetX = st.x_curr + (dy / Math.tan(bisector));
                    gk.x_curr += (targetX - gk.x_curr) * 0.1;
                }
                
                // GK 3: Refleks Membesar
                // Ekspansi 0.2m dalam gkReflexTime (ms)
                let expansionRate = (0.2 / (gkReflexTime / 1000)) * dt;
                if (gkType === 3 && gk.radius_block < 0.6) gk.radius_block += expansionRate;
            }
        }

        // Update posisi striker (Selalu bergerak/animasi)
        if(!st.manual) st.x_curr = st.x0 + st.A*Math.sin(st.omega*t + st.phi);

        // Fisika Bola
        if(ball.active){
            ball.x+=ball.vx*dt; ball.y+=ball.vy*dt;
            // Cek Tabrakan
            if(ball.y<=gk.y_pos && ball.y>=gk.y_pos-0.5 && Math.abs(ball.x-gk.x_curr)<=gk.radius_block){
                ball.active=false; 
                document.getElementById('shootBtn').disabled=false;
                gk.diveTimer = 30; // Efek visual selama 30 frame (0.5 detik)
                showMatchResult("BLOCKED!", "#ff1744"); // Merah Terang
            }
            // Cek Gawang
            if(ball.y<=0){ 
                // Koreksi posisi bola tepat di garis gawang (y=0)
                // Mengatasi overshoot karena simulasi per frame
                let exactX = ball.x - (ball.y / ball.vy) * ball.vx;
                ball.x = exactX; // Snap visual bola ke garis
                ball.y = 0;

                ball.active=false; 
                document.getElementById('shootBtn').disabled=false;
                
                // Cek apakah masuk gawang (antara -1.5 dan 1.5)
                if (Math.abs(ball.x) <= 1.5) {
                    showMatchResult("GOAL!!!", "#00e676"); 
                } else {
                    console.log("Result: MISSED");
                }
            }
        }
    }

    function shoot() { 
        if(ball.active)return; 
        ball.x=st.x_curr; ball.y=st.y_pos; ball.active=true;
        shotTime = t; // Catat waktu tembakan
        
        let targetX = 0;
        
        if (stType === 1) {
            // ST 1: Tiang Dekat (Near Post)
            targetX = (st.x_curr > 0) ? 1.3 : -1.3;
        } else if (stType === 2) {
            // ST 2: Tiang Jauh (Far Post)
            targetX = (st.x_curr > 0) ? -1.3 : 1.3;
        } else {
            // ST 3: Tiang Terjauh dari Kiper (Celah Terlebar)
            let distLeft = Math.abs(gk.x_curr - (-1.3));
            let distRight = Math.abs(gk.x_curr - 1.3);
            targetX = (distLeft > distRight) ? -1.3 : 1.3;
        }
        
        // --- TAMBAHAN: HUMAN ERROR (NOISE) ---
        // Menambahkan variasi acak +/- 0.3 meter agar visualisasi tidak kaku (deterministik)
        // Ini menyamakan logika visual dengan logika pengambilan data CSV
        targetX += (Math.random() - 0.5) * 0.6;
        
        let dx = targetX - ball.x;
        let dy = 0 - ball.y;
        let d=Math.sqrt(dx*dx+dy*dy), s=ballSpeed; 
        
        ball.vx=(dx/d)*s; ball.vy=(dy/d)*s;
        document.getElementById('shootBtn').disabled=true; 

        // --- LOG DETAIL xG SAAT MENEMBAK ---
        let finalXG = calculateXG();
        console.log(`SHOOT! Pos: (${st.x_curr.toFixed(2)}, ${st.y_pos.toFixed(2)}) | Speed: ${ballSpeed}m/s | Reflex: ${gkReflexTime}ms | xG: ${finalXG.toFixed(4)}`);
    }

    // --- ANIMASI HASIL (GOAL / MISS) ---
    function showMatchResult(text, color) {
        matchResult.text = text;
        matchResult.color = color;
        matchResult.timer = 120; // Durasi 2 detik (60fps * 2)
        matchResult.opacity = 1.0;
    }

    function drawMatchResult() {
        if (matchResult.timer > 0) {
            matchResult.timer--;
            
            // Efek Fade Out di akhir
            if (matchResult.timer < 30) matchResult.opacity = matchResult.timer / 30;

            ctx.save();
            ctx.globalAlpha = matchResult.opacity;
            
            // Style Teks
            ctx.font = "900 60px 'Segoe UI', Arial, sans-serif";
            ctx.textAlign = "center";
            ctx.textBaseline = "middle";
            
            // Stroke (Garis Tepi Hitam)
            ctx.lineWidth = 4;
            ctx.strokeStyle = "rgba(0,0,0,0.8)";
            ctx.strokeText(matchResult.text, canvas.width/2, canvas.height/2 - 50);
            
            // Fill (Warna Utama)
            ctx.fillStyle = matchResult.color;
            ctx.fillText(matchResult.text, canvas.width/2, canvas.height/2 - 50);
            
            ctx.restore();
        }
    }

    // --- INTERAKSI MOUSE (DRAG & DROP) ---
    let isDragging = false;

    canvas.addEventListener('mousedown', (e) => {
        const rect = canvas.getBoundingClientRect();
        const mx = (e.clientX - rect.left - ORIGIN_X) / SCALE;
        const my = (ORIGIN_Y - (e.clientY - rect.top)) / SCALE;
        
        // Cek apakah klik dekat striker (radius 1m)
        if(Math.sqrt((mx - st.x_curr)**2 + (my - st.y_pos)**2) < 1.0) {
            isDragging = true;
            st.manual = true; // Matikan gerak otomatis selamanya setelah diklik
            updateStBtnUI();
            canvas.style.cursor = "grabbing";
        }
    });

    canvas.addEventListener('mousemove', (e) => {
        const rect = canvas.getBoundingClientRect();
        const mx = (e.clientX - rect.left - ORIGIN_X) / SCALE;
        const my = (ORIGIN_Y - (e.clientY - rect.top)) / SCALE;

        if(isDragging) {
            st.x_curr = Math.max(-10, Math.min(10, mx)); // Batas lapangan X
            st.y_pos = Math.max(1, Math.min(20, my));    // Batas lapangan Y
        } else {
            // Efek hover kursor
            const dist = Math.sqrt((mx - st.x_curr)**2 + (my - st.y_pos)**2);
            canvas.style.cursor = dist < 1.0 ? "grab" : "default";
        }
    });

    canvas.addEventListener('mouseup', () => { isDragging = false; canvas.style.cursor = "grab"; });

    // --- INTERAKSI KEYBOARD ---
    // Inisialisasi Config Awal
    updateConfig();
    
    document.addEventListener('keydown', (e) => {
        if (e.code === "Space") {
            e.preventDefault(); // Mencegah scroll saat spasi ditekan
            shoot();
        }
    });

    function loop() { update(); drawField(); drawAgents(); drawMatchResult(); requestAnimationFrame(loop); }
    loop();
</script>
</body>
